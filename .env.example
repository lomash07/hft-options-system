# ==============================================
# HFT Options System — Environment Variables
# Copy to .env and fill in your values
# ==============================================

# ── Mode ──
TRADING_MODE=paper          # paper | live
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ── Database ──
DB_PASSWORD=hft_dev_2024
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hft_options

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Interactive Brokers ──
IB_HOST=127.0.0.1
IB_PORT=4002              # 4001=live, 4002=paper
IB_CLIENT_ID=1
IB_USERNAME=
IB_PASSWORD=

# ── Telegram Alerts ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Capital & Risk ──
TOTAL_CAPITAL=20000
MAX_RISK_PER_TRADE=400     # 2% of capital
MAX_RISK_PER_DAY=800       # 4% of capital
MAX_CONCURRENT_POSITIONS=5
OPTIONS_CAPITAL_PCT=0.80   # 80% to options
STOCK_CAPITAL_PCT=0.20     # 20% to stock scalps

# ── PDT ──
PDT_ENABLED=true           # Set false if account > $25K
PDT_MAX_DAY_TRADES=3       # Per rolling 5 business days

# ── Data Sources (Free Tier) ──
# Tradier sandbox (free, optional)
TRADIER_API_KEY=
TRADIER_SANDBOX=true

# Grafana
GRAFANA_PASSWORD=admin
